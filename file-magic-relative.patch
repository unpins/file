--- a/src/magic.c
+++ b/src/magic.c
@@ -29,6 +29,9 @@
 #include <windows.h>
 #include <shlwapi.h>
 #endif
+#ifdef __APPLE__
+#include <mach-o/dyld.h>
+#endif
 
 #include "file.h"
 
@@ -178,6 +181,44 @@
 	static char *default_magic;
 	char *home, *hmagicpath;
 
+#if defined(__linux__) || defined(__APPLE__)
+	/* unpins: look for magic.mgc relative to the running executable. file is
+	 * shipped as a single binary plus a companion `share/misc/magic.mgc`
+	 * extracted by `unpin install` next to it; the compiled-in MAGIC path
+	 * points into the Nix build store and doesn't exist on the target host.
+	 * Try `<exedir>/../share/misc/magic.mgc` first — matches the existing
+	 * Windows logic in _w32_get_magic_relative_to. */
+	{
+		char exepath[PATH_MAX];
+		ssize_t n = -1;
+#if defined(__linux__)
+		n = readlink("/proc/self/exe", exepath, sizeof(exepath) - 1);
+#elif defined(__APPLE__)
+		uint32_t sz = sizeof(exepath);
+		if (_NSGetExecutablePath(exepath, &sz) == 0)
+			n = (ssize_t)strlen(exepath);
+#endif
+		if (n > 0) {
+			char *slash, *relpath;
+			struct stat st;
+			exepath[n] = '\0';
+			slash = strrchr(exepath, '/');
+			if (slash != NULL)
+				*slash = '\0';
+			if (asprintf(&relpath, "%s/../share/misc/magic.mgc",
+			    exepath) >= 0) {
+				if (stat(relpath, &st) == 0) {
+					if (default_magic)
+						free(default_magic);
+					default_magic = relpath;
+					return default_magic;
+				}
+				free(relpath);
+			}
+		}
+	}
+#endif
+
 #ifndef WIN32
 	struct stat st;
 
