Embed the compiled magic database in the binary.

Upstream file expects $datadir/share/misc/magic.mgc on disk (or
$MAGIC, or ~/.magic.mgc). For unpins we ship a single binary, so
the build-time generated magic.mgc is embedded as `magic_mgc[]` in
src/embedded_magic.h (generated by the flake's postBuild before
relinking). file.c::load() hands it to magic_load_buffers when no
magic file is given on the command line and $MAGIC is unset;
user-supplied -m or $MAGIC still go through the regular magic_load
path so power users can override.

The blob is embedded uncompressed (~8.5MB). gzip-compressing it
(~440KB) didn't help in practice: the release artifact is itself
zstd-compressed for download, and zstd-19 over a pre-gzipped blob
recovers virtually nothing, so the final .zst was actually larger
than embedding raw. On disk after install the binary is ~8.5MB
either way, since file's compiled magic database is uniformly
dense and doesn't compress in-place. Keeping it raw also avoids
pulling zlib into a code path that previously didn't need it.

--- a/src/file.c
+++ b/src/file.c
@@ -67,6 +67,8 @@
 #include <ctype.h>
 #endif
 
+#include "embedded_magic.h"
+
 #if defined(HAVE_GETOPT_H) && defined(HAVE_STRUCT_OPTION)
 # include <getopt.h>
 # ifndef HAVE_GETOPT_LONG
@@ -327,7 +329,9 @@
 #endif
 			break;
 		case 'v':
-			if (magicfile == NULL)
+			if (magicfile == NULL && getenv("MAGIC") == NULL)
+				magicfile = "(embedded)";
+			else if (magicfile == NULL)
 				magicfile = magic_getpath(magicfile, action);
 			(void)fprintf(stdout, "%s-%s\n", file_getprogname(),
 			    VERSION);
@@ -493,6 +497,18 @@
 		file_warn("Can't create magic");
 		return NULL;
 	}
+
+	if (magicfile == NULL && getenv("MAGIC") == NULL &&
+	    magic_mgc_len > 0) {
+		void *bp = (void *)magic_mgc;
+		size_t sz = magic_mgc_len;
+		if (magic_load_buffers(magic, &bp, &sz, 1) == 0) {
+			if ((e = magic_error(magic)) != NULL)
+				file_warn("%s", e);
+			return magic;
+		}
+	}
+
 	if (magic_load(magic, magicfile) == -1) {
 		file_warn("%s", magic_error(magic));
 		magic_close(magic);
