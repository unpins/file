@@ -327,7 +329,9 @@
 #endif
 			break;
 		case 'v':
-			if (magicfile == NULL)
+			if (magicfile == NULL && getenv("MAGIC") == NULL)
+				magicfile = "(embedded)";
+			else if (magicfile == NULL)
 				magicfile = magic_getpath(magicfile, action);
 			(void)fprintf(stdout, "%s-%s\n", file_getprogname(),
 			    VERSION);
@@ -493,6 +497,18 @@
 		file_warn("Can't create magic");
 		return NULL;
 	}
+
+	if (magicfile == NULL && getenv("MAGIC") == NULL) {
+		void *bp;
+		size_t sz;
+		if (unpin_load_embedded_magic(&bp, &sz) == 0 &&
+		    magic_load_buffers(magic, &bp, &sz, 1) == 0) {
+			if ((e = magic_error(magic)) != NULL)
+				file_warn("%s", e);
+			return magic;
+		}
+	}
+
